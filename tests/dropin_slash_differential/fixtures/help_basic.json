{
  "scenario": "help_basic",
  "description": "Basic /help command should show available commands",
  "setup": [],
  "command": "/help",
  "expected_fields": [
    "commands",
    "status"
  ],
  "should_contain": [
    "Available commands",
    "/clear",
    "/model",
    "/thinking",
    "/exit"
  ],
  "should_not_contain": [
    "error",
    "unknown command"
  ]
}